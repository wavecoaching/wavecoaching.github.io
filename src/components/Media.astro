---
import YouTubeEmbed from './YouTubeEmbed.astro';
import InstagramEmbed from './InstagramEmbed.astro';

// Replace these video IDs with Chelsea's real YouTube videos
const youtubeVideos = [
  { videoId: 'dQw4w9WgXcQ', title: 'Open Water Swim Tips for Triathletes' },
  { videoId: 'dQw4w9WgXcQ', title: 'How to Improve Your Freestyle Stroke' },
];

// Replace these URLs with Chelsea's real Instagram post URLs
// e.g. 'https://www.instagram.com/p/XXXXXXXXXXX'
const instagramPosts: { postUrl: string; caption?: string }[] = [
  // { postUrl: 'https://www.instagram.com/p/XXXXXXXXXXX', caption: 'Post caption here' },
];

const hasInstagram = instagramPosts.length > 0;
---

<section id="media" class="py-20 bg-wave-blue-light">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="text-wave-pink font-semibold text-sm uppercase tracking-widest">Watch &amp; Follow</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-wave-blue-dark mt-2">Training Tips &amp; Coaching Insights</h2>
      <p class="mt-4 text-wave-gray max-w-xl mx-auto">
        Free swim and triathlon content — straight from the water.
      </p>
    </div>

    <!-- YouTube videos -->
    <div>
      <div class="flex items-center gap-3 mb-6">
        <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        <h3 class="text-xl font-bold text-wave-blue-dark">YouTube</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {youtubeVideos.map(v => (
          <YouTubeEmbed videoId={v.videoId} title={v.title} />
        ))}
      </div>
    </div>

    <!-- Instagram (only render if posts provided) -->
    {hasInstagram && (
      <div class="mt-14">
        <div class="flex items-center gap-3 mb-6">
          <svg class="w-6 h-6 text-wave-pink" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          <h3 class="text-xl font-bold text-wave-blue-dark">Instagram</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {instagramPosts.map(p => (
            <InstagramEmbed postUrl={p.postUrl} caption={p.caption} />
          ))}
        </div>
      </div>
    )}

    <!-- Instagram CTA (shown when no posts are embedded) -->
    {!hasInstagram && (
      <div class="mt-10 text-center">
        <a
          href="https://instagram.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-wave-pink hover:bg-wave-pink-dark text-white font-semibold px-6 py-3 rounded-xl transition-colors duration-200"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          Follow @WaveCoaching on Instagram
        </a>
      </div>
    )}

  </div>
</section>
