---
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    accent: 'blue' as const,
    icon: 'M15 10l4.553-2.069A1 1 0 0121 8.87V15.13a1 1 0 01-1.447.894L15 14M3 8h12a2 2 0 012 2v4a2 2 0 01-2 2H3a2 2 0 01-2-2v-4a2 2 0 012-2z',
    title: 'Swim Analysis',
    description: 'Detailed video analysis of your stroke to eliminate inefficiencies, reduce drag, and build a technique that lasts across the whole race.',
    features: [
      'Underwater & above-water video capture',
      'Frame-by-frame stroke breakdown',
      'Personalised drill prescription',
      'Written report + video feedback',
      'Follow-up comparison session available',
    ],
    ctaLabel: 'Book Analysis',
    ctaHref: '#booking',
  },
  {
    accent: 'pink' as const,
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    title: '1-on-1 Swim Lessons',
    description: 'Private coaching sessions at Redcliffe pools and open water — tailored entirely to your current level, goals, and race calendar.',
    features: [
      'Beginner to advanced all welcome',
      'Pool technique & open water confidence',
      'Race-start and sighting skills',
      'Flexible session scheduling',
      'Progress tracking between sessions',
    ],
    ctaLabel: 'Book a Lesson',
    ctaHref: '#booking',
  },
  {
    accent: 'peach' as const,
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
    title: 'Online Triathlon Coaching',
    description: 'Fully personalised training programs for Olympic, 70.3, and Full Ironman — built around your life, not the other way around.',
    features: [
      'Olympic, 70.3 & Full Ironman plans',
      'Weekly plan delivery via TrainingPeaks',
      'Monthly video check-in calls',
      'Swim, bike & run integration',
      'Nutrition & race-week guidance',
    ],
    ctaLabel: 'View Pricing',
    ctaHref: '#pricing',
  },
];
---

<section id="services" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="text-wave-pink font-semibold text-sm uppercase tracking-widest">What I Offer</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-wave-blue-dark mt-2">Coaching Services</h2>
      <p class="mt-4 text-wave-gray max-w-xl mx-auto">
        Whether you need technique work, private lessons, or a full season plan — there's a program built for you.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map(service => (
        <ServiceCard {...service} />
      ))}
    </div>
  </div>
</section>
