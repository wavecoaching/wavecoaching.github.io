---
import Logo from './Logo.astro';

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#services', label: 'Services' },
  { href: '#media', label: 'Media' },
  { href: '#pricing', label: 'Pricing' },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-wave-blue-light shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="#" class="flex-shrink-0" aria-label="Wave Coaching home">
        <Logo width="140" height="36" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-wave-gray hover:text-wave-blue font-medium transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#booking"
          class="bg-wave-pink hover:bg-wave-pink-dark text-white font-semibold px-4 py-2 rounded-lg transition-colors duration-200"
        >
          Book Now
        </a>
      </nav>

      <!-- Mobile hamburger via <details>/<summary> — zero JS -->
      <details class="md:hidden group">
        <summary class="list-none cursor-pointer p-2 rounded-lg hover:bg-wave-blue-light transition-colors" aria-label="Toggle menu">
          <!-- Hamburger icon -->
          <svg class="w-6 h-6 text-wave-blue group-open:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <!-- Close icon -->
          <svg class="w-6 h-6 text-wave-blue hidden group-open:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </summary>

        <!-- Mobile dropdown -->
        <div class="absolute top-16 left-0 right-0 bg-white border-b border-wave-blue-light shadow-lg px-4 py-4 flex flex-col gap-3">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="text-wave-gray hover:text-wave-blue font-medium py-1 transition-colors duration-200"
            >
              {link.label}
            </a>
          ))}
          <a
            href="#booking"
            class="bg-wave-pink hover:bg-wave-pink-dark text-white font-semibold px-4 py-2 rounded-lg text-center transition-colors duration-200 mt-1"
          >
            Book Now
          </a>
        </div>
      </details>

    </div>
  </div>
</header>
